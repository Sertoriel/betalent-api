{
  "info": {
    "name": "BeTalent API - Nível 2",
    "description": "Collection automatizada para testar a API de Pagamentos com Fallback do Desafio BeMobile (Nível 2). O Script de Login capta o token e abastece as rotas dinamicamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Signup (Criar Admin)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Administrador Sistema\",\n  \"email\": \"admin@betalent.com\",\n  \"password\": \"senha_segura_123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login (Gerar Token ScriptAutomático)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token && jsonData.token.token) {",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.token.token);",
                  "    console.log(\"Token Salvo Automaticamente!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@betalent.com\",\n  \"password\": \"senha_segura_123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
